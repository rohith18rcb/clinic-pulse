# Twilio WhatsApp Sandbox Credentials
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio WhatsApp Sandbox Number (always this for sandbox)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Your personal WhatsApp number for demo (include country code, no spaces)
# Example for India: +919876543210
YOUR_DEMO_WHATSAPP=+91XXXXXXXXXX

# Port for the server
PORT=3000

# ngrok public URL (set this after running ngrok)
# Example: https://abc123.ngrok-free.app
NGROK_URL=https://your-ngrok-url.ngrok-free.app
